# Application Configuration
APP_URL=http://localhost:5174
API_URL=http://localhost:5174
SESSION_SECRET=your-secret-key-here

# Email Configuration
# Choose one of the following email services:

# Option 1: Gmail
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_FROM=noreply@iu-portal.com

# Option 2: SendGrid
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your-sendgrid-api-key
# EMAIL_FROM=noreply@iu-portal.com

# Option 3: Development (Ethereal - no configuration needed)
# EMAIL_SERVICE=development
# This will create temporary email accounts for testing

# Database
DATABASE_URL=file:./dev.db
