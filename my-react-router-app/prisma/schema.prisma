// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  username        String    @unique
  password        String
  name            String?
  role            String    @default("STUDENT")
  resetToken      String?
  resetTokenExpiry DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Student ID fields
  matriculationNumber String?
  birthday        DateTime?
  studyProgram    String?
  validUntil      DateTime?
  
  // Semester tracking for onboarding
  semester        Int       @default(1)  // Current semester (1 = first semester)
  totalSemesters  Int       @default(6)  // Total semesters in program
  
  marks           Mark[]
  files           File[]
  studienplan     Studienplan?
  sessions        Session[]
  studiengang     Studiengang? @relation("UserStudiengang", fields: [studiengangId], references: [id])
  studiengangId   Int?
  praxisReports   PraxisReport[]
  roomBookings    RoomBooking[]

  // Daily email reminder preferences for Praxisbericht
  reminderEnabled  Boolean  @default(false)
  reminderHour     Int?
  reminderMinute   Int?     @default(0)
  reminderTimezone String   @default("Europe/Berlin")

  tasks            StudentTask[]
  
  // Forum relations
  forumTopics      ForumTopic[]
  forumPosts       ForumPost[]
  
  // Contact submissions
  contactSubmissions ContactSubmission[]
  
  // Dual Student relations
  praxisPartner     PraxisPartner?
  praxisHoursLogs   PraxisHoursLog[]
  praxisHoursTarget PraxisHoursTarget?
  scheduleEvents    ScheduleEvent[]
}

model Teacher {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  marks     Mark[]
}

model Mark {
  id        Int      @id @default(autoincrement())
  value     Float
  course    String
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  teacherId Int
}

model Studiengang {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  description String?
  createdAt DateTime @default(now())
  courses   Course[]
  files     File[]
  users     User[]   @relation("UserStudiengang")
}

model Course {
  id           Int      @id @default(autoincrement())
  code         String   @unique // e.g., "WEB101"
  name         String
  description  String?
  studiengang  Studiengang @relation(fields: [studiengangId], references: [id])
  studiengangId Int
  createdAt    DateTime @default(now())
  files        File[]
}

model File {
  id          Int      @id @default(autoincrement())
  name        String
  url         String
  fileType    String?  // "pdf", "doc", etc.
  size        String?  // e.g., "2.5 MB"
  uploadedAt  DateTime @default(now())
  lastOpenedAt DateTime?
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  course      Course?  @relation(fields: [courseId], references: [id])
  courseId    Int?
  studiengang Studiengang? @relation(fields: [studiengangId], references: [id])
  studiengangId Int?
  readingState FileReadingState?
}

model FileReadingState {
  id          Int      @id @default(autoincrement())
  file        File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  fileId      Int      @unique
  lastPage    Int?     // Last page number opened in PDF
  totalPages  Int?     // Total pages in PDF
  scrollPosition Float? // Scroll position in document
  bookmarks   String?  // JSON array of bookmarked pages/sections
  annotations String?  // JSON array of annotations
  readingProgress Float? // Percentage read (0-100)
  lastUpdated DateTime @default(now()) @updatedAt
}

model Studienplan {
  id        Int      @id @default(autoincrement())
  plan      String   // JSON or text representation
  user      User     @relation(fields: [userId], references: [id])
  userId    Int @unique
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum TaskKind {
  ABGABE
  KLAUSUR
}

model StudentTask {
  id        Int      @id @default(autoincrement())
  title     String
  course    String
  kind      TaskKind
  type      String
  dueDate   DateTime
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Weekly practical report per user and ISO week
enum PraxisStatus {
  DUE
  SUBMITTED
  APPROVED
  KLAUSUR
  DRAFT
  KLAUSURPHASE
}

model PraxisReport {
  id         Int           @id @default(autoincrement())
  isoWeekKey String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  // JSON object with keys Mon..Sun or similar shape
  days       Json
  tasks      String
  grade      Int           @default(0)
  status     PraxisStatus  @default(DUE)
  editedAt   DateTime      @default(now())
  approvedAt DateTime?
  createdAt  DateTime      @default(now())

  @@unique([isoWeekKey, userId], name: "isoWeekKey_userId")
}

// News content for students
enum NewsStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model News {
  id            Int        @id @default(autoincrement())
  slug          String     @unique
  title         String
  excerpt       String?
  content       String
  category      String?
  tags          String?    // JSON-encoded string array
  author        String?
  coverImageUrl String?
  featured      Boolean    @default(false)
  status        NewsStatus @default(PUBLISHED)
  publishedAt   DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([publishedAt, featured])
}

// Room Booking for campus rooms
model RoomBooking {
  id        Int      @id @default(autoincrement())
  roomId    String   // e.g., "HB-A1", "WL-C2"
  roomName  String   // e.g., "Raum A1", "Raum C2"
  campus    String   // "Hammerbrook" or "Waterloohain"
  date      DateTime
  startTime String   // e.g., "09:00"
  endTime   String   // e.g., "11:00"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date, campus, roomId])
  @@index([userId, date])
}

// FAQ - Frequently Asked Questions
model FAQ {
  id        Int      @id @default(autoincrement())
  question  String   @unique
  answer    String
  category  String   // e.g., "studium", "prüfungen", "praxisphase", "angebote"
  keywords  String?  // JSON array of keywords for better search
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// Forum Models
model ForumTopic {
  id        Int         @id @default(autoincrement())
  title     String
  content   String
  courseId  Int
  author    User        @relation(fields: [authorId], references: [id])
  authorId  Int
  views     Int         @default(0)
  pinned    Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  posts     ForumPost[]

  @@index([courseId])
}

model ForumPost {
  id        Int        @id @default(autoincrement())
  content   String
  topic     ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  topicId   Int
  author    User       @relation(fields: [authorId], references: [id])
  authorId  Int
  likes     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// Contact Form Submissions
enum ContactStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model ContactSubmission {
  id        Int           @id @default(autoincrement())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  subject   String
  message   String
  status    ContactStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// Praxis Partner (Dual Student Company)
model PraxisPartner {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName  String
  department   String?
  supervisor   String?
  email        String?
  phone        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Praxis Hours Tracking (for dual students)
model PraxisHoursLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime
  hours       Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
}

// Praxis Hours Target (semester goals)
model PraxisHoursTarget {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requiredHours   Int      @default(900)  // per semester
  targetPerWeek   Int      @default(40)
  semesterStart   DateTime
  semesterEnd     DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Schedule Event (for course schedule / Stundenplan)
enum ScheduleEventType {
  VORLESUNG
  SEMINAR
  UEBUNG
  TUTORIUM
  WORKSHOP
  PRUEFUNG
  SONSTIGES
}

model ScheduleEvent {
  id          Int               @id @default(autoincrement())
  userId      Int?
  user        User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  courseCode  String?           // e.g., "DLBINGDT01"
  date        DateTime
  startTime   String            // e.g., "10:00"
  endTime     String            // e.g., "11:30"
  location    String?           // e.g., "Hammerbrook"
  eventType   ScheduleEventType @default(VORLESUNG)
  professor   String?
  isRecurring Boolean           @default(false)
  recurringDays String?         // JSON array of days ["MO", "WE", "FR"]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId, date])
  @@index([date])
}
