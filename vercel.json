{
  "framework": null,
  "installCommand": "cd my-react-router-app && npm install && npx prisma format && npx prisma validate && npx prisma generate",
  "buildCommand": "cd my-react-router-app && npm run build",
  "outputDirectory": "my-react-router-app/build/client",
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/praxisbericht-reminder",
      "schedule": "0 17 * * 5"
    },
    {
      "path": "/api/cron/daily-reminders",
      "schedule": "0 18 * * *"
    }
  ]
}
